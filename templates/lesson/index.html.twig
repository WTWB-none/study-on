{% extends 'base.html.twig' %}

{% block title %}Lesson index{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
            <h1 class="mb-0">Уроки</h1>
            <a class="btn btn-primary" href="{{ path('app_lesson_new') }}">Добавить урок</a>
        </div>

        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Название</th>
                            <th>Порядок</th>
                            <th>Содержание</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for lesson in lessons %}
                        <tr>
                            <td>{{ lesson.id }}</td>
                            <td>{{ lesson.name }}</td>
                            <td>{{ lesson.lessonNum }}</td>
                            <td>{{ lesson.lessonContent|length > 80 ? lesson.lessonContent|slice(0, 80) ~ '...' : lesson.lessonContent }}</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_lesson_show', {'id': lesson.id}) }}">Открыть</a>
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_lesson_edit', {'id': lesson.id}) }}">Изменить</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-body-secondary py-4">Уроков пока нет.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
