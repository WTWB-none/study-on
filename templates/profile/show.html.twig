{% extends 'base.html.twig' %}

{% block title %}Профиль{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-7">
                <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
                    <h1 class="mb-0">Профиль</h1>
                    <a class="btn btn-outline-secondary" href="{{ path('app_course_index') }}">К курсам</a>
                </div>

                <div class="card shadow-sm">
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">{{ user.email }}</dd>

                            <dt class="col-sm-4">Роль</dt>
                            <dd class="col-sm-8">{{ role_label }}</dd>

                            <dt class="col-sm-4">Баланс</dt>
                            <dd class="col-sm-8">{{ user.balance|number_format(2, '.', ' ') }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
