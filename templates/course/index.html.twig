{% extends 'base.html.twig' %}

{% block title %}Course index{% endblock %}

{% block body %}
        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
                <h1 class="mb-0">Курсы</h1>
                {% if is_granted('ROLE_SUPER_ADMIN') %}
                    <a class="btn btn-primary" href="{{ path('app_course_new') }}">Добавить курс</a>
                {% endif %}
        </div>

        <div class="row row-cols-1 row-cols-lg-2 g-3">
            {% for course in courses %}
                <div class="col">
                    <article class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h2 class="h4 card-title">
                                {{ course.name }}
                            </h2>
                            <p class="card-text mb-0">{{ course.description }}</p>
                            <a class="text-decoration-none" href="{{ path('app_course_show', {'id': course.id}) }}">пройти</a>
                        </div>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">Курсов пока нет.</div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
