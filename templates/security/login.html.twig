{% extends 'base.html.twig' %}

{% block title %}Вход{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h1 class="h3 mb-4">Вход</h1>

                        {% if app.user %}
                            <div class="alert alert-info">
                                Вы вошли как {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">выйти</a>
                            </div>
                        {% endif %}

                        <form method="post">
                            {% if error %}
                                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                            {% endif %}

                            <div class="mb-3">
                                <label class="form-label" for="inputEmail">Email</label>
                                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="inputPassword">Пароль</label>
                                <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                            </div>

                            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                            <div class="checkbox mb-3">
                                <label>
                                    <input type="checkbox" name="_remember_me"> Запомнить меня
                                </label>
                            </div>

                            <button class="btn btn-primary w-100" type="submit">
                                Войти
                            </button>
                        </form>

                        <p class="mt-3 mb-0 text-center">
                            Нет аккаунта?
                            <a href="{{ path('app_register') }}">Зарегистрироваться</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
